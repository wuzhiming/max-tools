<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- V8 / Electron need JIT + writeable executable memory under hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- sharp ships native dylibs (@img/sharp-darwin-*) that aren't validated
       against the app's signing identity — library validation must be off. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Some Electron flag plumbing relies on dyld env variables. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
